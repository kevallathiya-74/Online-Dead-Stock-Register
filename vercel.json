{
  "installCommand": "npm install --prefix frontend",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://deadstockapp.onrender.com/api/:match*"
    },
    {
      "source": "/((?!assets|favicon\\.ico|logo.*\\.png|manifest\\.json|robots\\.txt).*)",
      "destination": "/index.html"
    }
  ]
}
