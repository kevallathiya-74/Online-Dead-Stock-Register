# ==============================================================================
#                 DEADSTOCKAPP - BACKEND CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' in local development, or copy the variables below
# to your production hosting dashboard (Render, Railway, etc.).
# ==============================================================================

# ==========================================
# 💻 SECTION 1: LOCAL DEVELOPMENT SETUP
# ==========================================
# Copy the variables below directly into 'backend/.env' for local runs:

NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ⚡ Supabase Local Connections
SUPABASE_URL=https://zcchsauxpvyokkxxwznh.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
SUPABASE_SECRET_KEY=your_supabase_service_role_key
SUPABASE_JWKS_URL=https://zcchsauxpvyokkxxwznh.supabase.co/auth/v1/.well-known/jwks.json

# 🔐 Local JWT Security
# Generate secure key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=local_development_jwt_secret_key_32_characters

# 📦 Uploads & Logging
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
LOG_LEVEL=debug
TIMEZONE=UTC

# 🗄️ Local Redis (Set to true if Redis is running locally, otherwise false)
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379

# 📧 SMTP Email Setup (Optional)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@deadstockapp.com
EMAIL_FROM_NAME=DeadStockApp


# ==========================================
# 🚀 SECTION 2: PRODUCTION DEPLOYMENT SETUP
# ==========================================
# Set these variables in your hosting dashboard (Render/Railway/Vercel):

# NODE_ENV=production
# PORT=10000
# FRONTEND_URL=https://deadstockapp.vercel.app
# ALLOWED_ORIGINS=https://deadstockapp.vercel.app

# ⚡ Supabase Production Connections (Use live Supabase keys)
# SUPABASE_URL=https://zcchsauxpvyokkxxwznh.supabase.co
# SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
# SUPABASE_SECRET_KEY=your_supabase_service_role_key
# SUPABASE_JWKS_URL=https://zcchsauxpvyokkxxwznh.supabase.co/auth/v1/.well-known/jwks.json

# 🔐 Production JWT Security (Must be a cryptographically secure random string!)
# JWT_SECRET=your_production_secure_32_character_hex_key

# 📦 Uploads & Logging
# UPLOAD_DIR=uploads
# MAX_FILE_SIZE=5242880
# LOG_LEVEL=info
# TIMEZONE=UTC

# 🗄️ Production Redis (Use a cloud provider like Upstash)
# REDIS_ENABLED=true
# REDIS_URL=rediss://default:your_password@your_upstash_host.upstash.io:6379

# 📧 SMTP Email Setup (Use SendGrid, Resend, or SMTP)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=apikey
# EMAIL_PASSWORD=your_sendgrid_api_key
# EMAIL_FROM=noreply@deadstockapp.com
# EMAIL_FROM_NAME=DeadStockApp
