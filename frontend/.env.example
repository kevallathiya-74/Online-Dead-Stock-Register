# ==============================================================================
#                 DEADSTOCKAPP - FRONTEND CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' in local development, or copy the variables below
# to your Vercel project environment variables dashboard.
# ==============================================================================

# ==========================================
# 💻 SECTION 1: LOCAL DEVELOPMENT SETUP
# ==========================================
# Copy the variables below directly into 'frontend/.env' for local runs:

VITE_NODE_ENV=development

# Leave VITE_API_BASE_URL blank in local development to use Vite's built-in 
# proxy (which automatically forwards /api to http://localhost:5000)
VITE_API_BASE_URL=


# ==========================================
# 🚀 SECTION 2: PRODUCTION DEPLOYMENT SETUP
# ==========================================
# Set these variables in your Vercel Dashboard Settings -> Environment Variables:

# VITE_NODE_ENV=production
# VITE_API_BASE_URL=https://deadstockapp.onrender.com/api/v1
